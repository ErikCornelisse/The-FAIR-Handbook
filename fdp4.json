{"version":3,"kind":"Article","sha256":"163c7bafcfb41e42a38a2a2406cb520892354b3da0deffc4af7a07da534ed96b","slug":"fdp4","location":"/The-FAIR-Handbook/fdp4.md","dependencies":[],"frontmatter":{"title":"Matching Layers","content_includes_title":false,"github":"https://github.com/dualslash/The-FAIR-Handbook","numbering":{"title":{"offset":3}},"source_url":"https://github.com/dualslash/The-FAIR-Handbook/blob/main/The-FAIR-Handbook/fdp4.md","edit_url":"https://github.com/dualslash/The-FAIR-Handbook/edit/main/The-FAIR-Handbook/fdp4.md","thumbnail":"/build/datainterface-27876453005e45cac96254a42e32455a.png","exports":[{"format":"md","filename":"fdp4.md","url":"/build/fdp4-833d9d996fff76740c822719733e6303.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"Metadata should be matched internally with data which it represents. The idea of FAIR principles realization is that the external users can access only metadata layer, and cannot reach data which resides internally only.","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"w8copdpqGU"}],"key":"fMZ8rqJawu"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"The request for data is typically made in terms of metadata, and that request should be translated internally by metadata layer to match schema of data. This matching happens internally, and user from outside doesn’t see the actual schema (if the actual schema is confidential).","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"GcVd2pOcn0"}],"key":"jKYhBMttWF"},{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"The relationship between metadata and data interfaces from the technical side is presented in the Figure below.","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"NIGkinEUQl"}],"key":"rQxR9Q9qNN"},{"type":"paragraph","children":[{"type":"image","url":"/build/datainterface-27876453005e45cac96254a42e32455a.png","height":422,"key":"PZ5dIcMz8i","urlSource":"./_static/img/datainterface.png"},{"type":"text","value":" ","key":"CuA3WvTltR"},{"type":"break","key":"Rqis8iRmLC"},{"type":"text","value":"TNO, EFRO.","key":"i4VWlrQkmH"}],"key":"m3jcYyvAyG"}],"key":"r8hlicr2mV"}],"key":"C4u7r5yNUR"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Metadata Layer","url":"/fdp3","group":"Phase 4: Integration — Technical Architecture & Privacy"},"next":{"title":"Metadata Standards","url":"/fdp5","group":"Phase 4: Integration — Technical Architecture & Privacy"}}},"domain":"http://localhost:3000"}