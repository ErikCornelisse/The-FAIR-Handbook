{"version":3,"kind":"Article","sha256":"4eb9410f053beee069ed358faa7cbdb8c08d84cbda49729cd8e21782aebb7050","slug":"f3","location":"/The-FAIR-Handbook/f3.md","dependencies":[],"frontmatter":{"title":"Metadata Linkage","content_includes_title":false,"github":"https://github.com/dualslash/The-FAIR-Handbook","numbering":{"title":{"offset":3}},"source_url":"https://github.com/dualslash/The-FAIR-Handbook/blob/main/The-FAIR-Handbook/f3.md","edit_url":"https://github.com/dualslash/The-FAIR-Handbook/edit/main/The-FAIR-Handbook/f3.md","exports":[{"format":"md","filename":"f3.md","url":"/build/f3-acc22663705ef103f233d19247374e8e.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"This is a simple and obvious principle, but of critical importance to FAIR. The metadata and the dataset they describe are usually separate files. The association between a metadata file and the dataset should be made explicit by mentioning a dataset’s globally unique and persistent identifier in the metadata.","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"BgjiBKLzBY"}],"key":"kDBlcmSIyR"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"As stated in F1, many repositories will generate globally unique and persistent identifiers for deposited  datasets that can be used for this purpose.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"mM6UWtCUv0"}],"key":"GJW9iszwG0"},{"type":"paragraph","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"link","url":"https://www.go-fair.org/fair-principles/f3-metadata-clearly-explicitly-include-identifier-data-describe/","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"inlineCode","value":"F3: Metadata c