{"version":3,"kind":"Article","sha256":"3c45b7779d45f8da2860df42d476d3072f06c54afe0762d13f1da0db60141e94","slug":"i3","location":"/The-FAIR-Handbook/i3.md","dependencies":[],"frontmatter":{"title":"Qualified References","content_includes_title":false,"github":"https://github.com/dualslash/The-FAIR-Handbook","numbering":{"title":{"offset":3}},"source_url":"https://github.com/dualslash/The-FAIR-Handbook/blob/main/The-FAIR-Handbook/i3.md","edit_url":"https://github.com/dualslash/The-FAIR-Handbook/edit/main/The-FAIR-Handbook/i3.md","exports":[{"format":"md","filename":"i3.md","url":"/build/i3-c66fdb5a097d500ad182ba5fd8b4c085.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"A qualified reference is a cross-reference that explains its intent. For example, ","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"b0kjgdAdNt"},{"type":"emphasis","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"X is regulator of Y","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"nt7v3tyCNz"}],"key":"jbZMSHAnRl"},{"type":"text","value":" is a much more qualified reference than ","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"iyVKaFosdB"},{"type":"emphasis","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"X is associated with Y","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"a3z3xkjlCi"}],"key":"uHMzhdMGKS"},{"type":"text","value":", or ","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"WiRxh7aVM4"},{"type":"emphasis","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"X see also Y","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"Qmdgkrt0jm"}],"key":"RXZlFrZz3P"},{"type":"text","value":".","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"bz6qP94x9A"}],"key":"mJek0iFWj7"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"The goal therefore is to create as many meaningful links as possible between (meta)data resources to enrich the contextual knowledge about the data, balanced against the time/energy involved in making a good data model.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"VEPYJiaPVb"}],"key":"tgAxyJA4na"},{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"To be more concrete, you should specify if one dataset builds on another data set, if additional datasets are needed to  complete the data, or if complementary information is stored in a  different dataset. In particular, the scientific links between the datasets need to be described. Furthermore, all datasets need to be  properly cited (i.e., including their globally unique and persistent  identifiers).","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"Cr3Mhh4BRK"}],"key":"FoNxvWlrqc"},{"type":"paragraph","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"link","url":"https://www.go-fair.org/fair-principles/i3-metadata-include-qualified-references-metadata/","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"inlineCode","value":"I3: (Meta)data include qualified references to other (meta)data","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"cKJlHx9o4J"}],"urlSource":"https://www.go-fair.org/fair-principles/i3-metadata-include-qualified-references-metadata/","key":"CQtXXVzXsG"}],"key":"Ft9QUVwB5O"}],"key":"YC38qHjyyp"}],"key":"ALmYVhA4jk"},"references":{"cit