{"version":3,"kind":"Article","sha256":"2767654c49db169194f7fbea2a8e1b807b1b4e52615b424e6aa377dc6b794608","slug":"fdp5","location":"/The-FAIR-Handbook/fdp5.md","dependencies":[],"frontmatter":{"title":"Metadata Standards","content_includes_title":false,"github":"https://github.com/dualslash/The-FAIR-Handbook","numbering":{"title":{"offset":3}},"source_url":"https://github.com/dualslash/The-FAIR-Handbook/blob/main/The-FAIR-Handbook/fdp5.md","edit_url":"https://github.com/dualslash/The-FAIR-Handbook/edit/main/The-FAIR-Handbook/fdp5.md","exports":[{"format":"md","filename":"fdp5.md","url":"/build/fdp5-c0ac2ff4f4a8f9563f089033e51e424f.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"Most metadata in datasets are added using ontologies. ","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"xBqXupilXv"},{"type":"strong","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"Ontologies","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"GeOreJ6EJ0"}],"key":"zXu5B0nFi8"},{"type":"text","value":" contain formal specifications of terms and relationships between them. You can think of them as dictionaries, where every word in the dictionary (a concept) has a unique identifier (concept ID) and is described by other words from that dictionary (definitions and relationships).","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"a05G8eeACJ"}],"key":"g0P06yh8Ma"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"Since all concepts in the ontology are unique and defined by their relations with other concepts, they give a good explanation of what the concept means and how it is related to other concepts. There are many different ontol