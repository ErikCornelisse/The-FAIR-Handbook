oyoyyEW1p"}],"key":"uKpg6V7l7Y"},{"type":"paragraph","position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"children":[{"type":"text","value":"These guidelines have seen rapid adaptation by the scientific community as well as the public sector, with the private sector also showing interest in the value that FAIR can bring. FAIR not only makes your data more manageable, but also makes your data more valuable by increasing the scope of possible application, speeding up data exploration and encouraging reuse of existing data sources.","position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"key":"VRSHLnGCL5"}],"key":"s5CPdZsU6m"},{"type":"admonition","kind":"seealso","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"See Also","key":"XRpnOjDYjX"}],"key":"ujfkmHRtJq"},{"type":"paragraph","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"children":[{"type":"text","value":"To already get a glimpse of the possibilities that are enabled by FAIR data, see ","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"key":"kRc1Qn7OwE"},{"type":"link","url":"https://www.tno.nl/en/focus-areas/information-communication-technology/roadmaps/data-sharing/federated-learning/","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"children":[{"type":"text","value":"this article on privacy-preserving data analysis","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"key":"aJuwDNVg5O"}],"urlSource":"https://www.tno.nl/en/focus-areas/information-communication-technology/roadmaps/data-sharing/federated-learning/","key":"VY8A4Jl1Lr"},{"type":"text","value":" presented by TNO.","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"key":"bC1fo4Wc5o"}],"key":"nt2zUGakFL"}],"key":"Ay3PocqfLj"},{"type":"paragraph","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"children":[{"type":"text","value":"Acquiring and storing data can be expensive. More reuse of existing data means a lower operational overhead and a more sustainable data strategy. In this digital handbook we will cover each of the aspects of FAIR and how FAIR can be implemented as a business data strategy. In addition we will discuss the importance of FAIR data and services, the core principles, use cases, as well as related technologies.","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"key":"q61a27MKq7"}],"key":"Z0jwtCjeIL"}],"key":"y9Axe7YbeV"}],"key":"hpfhJNVVQl"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Model to Data","url":"/dss4","group":"Phase 1: Explore — Value, Stakeholders & Use Cases"},"next":{"title":"Findable","url":"/findable","group":"Phase 2: Govern — FAIR Principles & Data Governance"}}},"domain":"http://localhost:3000"}